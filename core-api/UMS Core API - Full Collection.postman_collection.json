          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let token;",
                  "try { const json = pm.response.json(); token = json && json.user && json.user.token; } catch (e) {}",
                  "if (token) { pm.collectionVariables.set('token', token); }"
                ]
